{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hayashi3017.github.io/zatsu-book/schemas/fact.schema.json",
  "title": "Fact",
  "type": "object",
  "required": [
    "id",
    "title",
    "primary_genre",
    "genres",
    "summary",
    "claim",
    "sources",
    "status",
    "created_at",
    "updated_at",
    "revision"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+-\\d{3}-[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": {
      "type": "string"
    },
    "primary_genre": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "genres": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      }
    },
    "summary": {
      "type": "string"
    },
    "claim": {
      "type": "string"
    },
    "explanation": {
      "type": "string"
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "url",
          "title",
          "publisher",
          "kind",
          "accessed_at"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "title": {
            "type": "string"
          },
          "publisher": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "enum": ["official", "primary", "secondary", "media", "other"]
          },
          "accessed_at": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "quoted_fact": {
            "type": "string"
          }
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["draft", "published", "duplicate", "superseded", "archived"]
    },
    "created_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "updated_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "duplicate_of": {
      "type": ["string", "null"]
    },
    "supersedes": {
      "type": ["string", "null"]
    },
    "canonical": {
      "type": "boolean"
    },
    "importance": {
      "type": ["number", "null"],
      "minimum": 0.0,
      "maximum": 1.0
    },
    "editorial": {
      "type": "object",
      "properties": {
        "tone": {
          "type": "string"
        },
        "audience": {
          "type": "string"
        },
        "spoiler": {
          "type": "boolean"
        }
      }
    }
  }
}
